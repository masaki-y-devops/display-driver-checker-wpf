<Window x:Class="MySimpleDisplayDriverChecker.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MySimpleDisplayDriverChecker" Height="300" Width="450"
        AllowDrop="True" Drop="Window_Drop" ResizeMode="NoResize">
    <!-- ここでドロップを許可 -->

    <Grid Margin="20">
        <Border BorderBrush="#CCC" BorderThickness="2" CornerRadius="10" Background="#F9F9F9">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="ここにディスプレイドライバのインストーラーファイル" 
                           FontSize="16" Foreground="#666" HorizontalAlignment="Center"/>
                <TextBlock Text="をドラッグ＆ドロップしてください"
                           FontSize="16" Foreground="#666" HorizontalAlignment="Center"/>
                <TextBlock x:Name="StatusText" Text="待機中..." 
                           HorizontalAlignment="Center" Margin="0,20,0,0" Foreground="Gray"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
